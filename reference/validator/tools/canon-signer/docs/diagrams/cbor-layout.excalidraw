      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false,
      "text": "SHA-256 over the whole array bytes  →  event_hash (64 hex chars)",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 13,
      "containerId": null,
      "originalText": "SHA-256 over the whole array bytes  →  event_hash (64 hex chars)",
      "lineHeight": 1.25
    },
    {
      "id": "rectangle-18282fdc",
