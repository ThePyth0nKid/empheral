      "text": "Canonical CBOR Payload — the exact bytes that get signed",
      "fontSize": 24,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 20,
      "containerId": null,
      "originalText": "Canonical CBOR Payload — the exact bytes that get signed",
      "lineHeight": 1.25
    },
    {
      "id": "text-2f5ee90a",
      "type": "text",
      "x": 40,
      "y": 56,
      "width": 754,
      "height": 18,
      "angle": 0,
      "strokeColor": "#666",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3
      },
      "seed": 1990160959,
      "version": 1,
      "versionNonce": 1117274462,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false,
      "text": "Positional array of 7.  No map, no keys, no ordering ambiguity.  RFC 8949 §4.2 deterministic.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 11,
      "containerId": null,
      "originalText": "Positional array of 7.  No map, no keys, no ordering ambiguity.  RFC 8949 §4.2 deterministic.",
      "lineHeight": 1.25
    },
    {
