      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false,
      "text": "CBOR header byte:  0x87   (= major type 4 = array, short count = 7)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 11,
      "containerId": null,
      "originalText": "CBOR header byte:  0x87   (= major type 4 = array, short count = 7)",
