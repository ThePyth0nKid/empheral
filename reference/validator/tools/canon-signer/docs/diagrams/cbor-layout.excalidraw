      "version": 1,
      "versionNonce": 1405588806,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false
    },
    {
      "id": "text-d8f23aef",
      "type": "text",
      "x": 380,
      "y": 470,
      "width": 334,
      "height": 19,
      "angle": 0,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3
      },
      "seed": 205547874,
      "version": 1,
      "versionNonce": 1998825374,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false,
      "text": "Why bstr for parent_hash (not tstr)?",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 12,
      "containerId": null,
      "originalText": "Why bstr for parent_hash (not tstr)?",
      "lineHeight": 1.25
    },
    {
      "id": "text-2ab8574c",
      "type": "text",
      "x": 380,
      "y": 510,
      "width": 584,
      "height": 30,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3
      },
      "seed": 1809308528,
      "version": 1,
      "versionNonce": 163053482,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false,
      "text": "• Hex case ambiguity would make 'AB' and 'ab' distinct text but identical bytes.\n• Genesis = empty bstr (0x40), byte-distinct from empty tstr (0x60). No ambiguity.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 11,
      "containerId": null,
      "originalText": "• Hex case ambiguity would make 'AB' and 'ab' distinct text but identical bytes.\n• Genesis = empty bstr (0x40), byte-distinct from empty tstr (0x60). No ambiguity.",
      "lineHeight": 1.25
    },
    {
      "id": "rectangle-569ee93a",
      "type": "rectangle",
      "x": 740,
      "y": 450,
      "width": 580,
      "height": 110,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "#f0fff4",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3
      },
      "seed": 571804467,
      "version": 1,
      "versionNonce": 56751895,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false
    },
    {
      "id": "text-f5a7f4ee",
      "type": "text",
      "x": 1030,
      "y": 470,
      "width": 181,
      "height": 19,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3
      },
      "seed": 1709487162,
      "version": 1,
      "versionNonce": 1987118850,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false,
      "text": "Why array, not map?",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 12,
      "containerId": null,
      "originalText": "Why array, not map?",
      "lineHeight": 1.25
    },
    {
      "id": "text-db6ba84d",
      "type": "text",
      "x": 1030,
      "y": 510,
      "width": 514,
      "height": 30,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": {
        "type": 3
      },
      "seed": 1638599096,
      "version": 1,
      "versionNonce": 1840659666,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713974400000,
      "link": null,
      "locked": false,
      "text": "A map has key-ordering rules that libraries can drift on.\nA positional array is canonical by construction — no keys exist to sort.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 11,
      "containerId": null,
      "originalText": "A map has key-ordering rules that libraries can drift on.\nA positional array is canonical by construction — no keys exist to sort.",
      "lineHeight": 1.25
    }
  ],
